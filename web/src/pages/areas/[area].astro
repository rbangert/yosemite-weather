---
import Layout from '../../layouts/Layout.astro';
import ObsTable from '../../components/ObsTable.astro';
import SummaryCard from '../../components/SummaryCard.astro';
import PeriodForecast from '../../components/PeriodForecast.astro';
import { fetchOverview, fetchForecast, fetchLatestObservation, fetchPeriodForecast } from '../../lib/api';
import type { AreaOverview, ForecastRow, ObservationRow, PeriodForecastRow } from '../../lib/api';

const { area } = Astro.params;
if (!area) return Astro.redirect('/');

// One representative station per area drives the summary card and 7-day forecast.
const AREA_REP: Record<string, { slug: string; name: string }> = {
  'valley-west':  { slug: 'yosemite-valley', name: 'Yosemite Valley' },
  'south':        { slug: 'wawona',           name: 'Wawona' },
  'high-country': { slug: 'tuolumne-meadows', name: 'Tuolumne Meadows' },
};

const rep = AREA_REP[area] ?? null;

let areaData: AreaOverview | undefined;
let repForecast: ForecastRow[] = [];
let repObservation: ObservationRow | null = null;
let repPeriods: PeriodForecastRow[] = [];
let error: string | null = null;

try {
  const [allAreas, forecast, observation, periods] = await Promise.all([
    fetchOverview(),
    rep ? fetchForecast(rep.slug) : Promise.resolve([]),
    rep ? fetchLatestObservation(rep.slug) : Promise.resolve(null),
    rep ? fetchPeriodForecast(rep.slug) : Promise.resolve([]),
  ]);
  areaData = allAreas.find(a => a.slug === area);
  repForecast = forecast;
  repObservation = observation;
  repPeriods = periods;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load weather data';
}

if (!areaData && !error) {
  return new Response(null, { status: 404 });
}
---

<Layout title={areaData?.name ?? 'Area'}>
  <div class="mx-auto max-w-7xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-slate-100">{areaData?.name}</h1>
      <p class="mt-1 text-sm text-slate-400">Current conditions · NOAA/NWS</p>
    </div>

    {error && (
      <div class="mb-6 rounded-lg border border-red-800 bg-red-950 p-4 text-sm text-red-300">
        Could not load weather data: {error}
      </div>
    )}

    {rep && (
      <SummaryCard pointName={rep.name} observation={repObservation} forecast={repForecast} />
    )}

    <PeriodForecast periods={repPeriods} />

    {areaData && (
      <ObsTable points={areaData.points} areaSlug={area} />
    )}
  </div>
</Layout>
