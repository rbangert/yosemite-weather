---
import Layout from '../layouts/Layout.astro';
import ObsTable from '../components/ObsTable.astro';
import SummaryCard from '../components/SummaryCard.astro';
import PeriodForecast from '../components/PeriodForecast.astro';
import SunMoonCard from '../components/SunMoonCard.astro';
import AvalancheCard from '../components/AvalancheCard.astro';
import { fetchOverview, fetchForecast, fetchLatestObservation, fetchPeriodForecast, fetchAvalancheZones } from '../lib/api';
import type { AreaOverview, ForecastRow, ObservationRow, PeriodForecastRow, AvalancheZoneSummary } from '../lib/api';

// Yosemite Valley is the canonical representative for the Valley & West area.
const REP_SLUG = 'yosemite-valley';
const REP_NAME = 'Yosemite Valley';
const REP_LAT = 37.74539;
const REP_LON = -119.59244;

let areaData: AreaOverview | undefined;
let repForecast: ForecastRow[] = [];
let repObservation: ObservationRow | null = null;
let repPeriods: PeriodForecastRow[] = [];
let avalancheZones: AvalancheZoneSummary[] = [];
let error: string | null = null;

try {
  const [allAreas, forecast, observation, periods] = await Promise.all([
    fetchOverview(),
    fetchForecast(REP_SLUG),
    fetchLatestObservation(REP_SLUG),
    fetchPeriodForecast(REP_SLUG),
  ]);
  areaData = allAreas.find(a => a.slug === 'valley-west');
  repForecast = forecast;
  repObservation = observation;
  repPeriods = periods;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load weather data';
}

// Avalanche zones are best-effort and never block the weather page.
avalancheZones = await fetchAvalancheZones();
---

<Layout title="Valley & West">
  <div class="mx-auto max-w-7xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-slate-100">Valley &amp; West</h1>
      <p class="mt-1 text-sm text-slate-400">Current conditions · NOAA/NWS</p>
    </div>

    {error && (
      <div class="mb-6 rounded-lg border border-red-800 bg-red-950 p-4 text-sm text-red-300">
        Could not load weather data: {error}
      </div>
    )}

    <SummaryCard pointName={REP_NAME} observation={repObservation} forecast={repForecast} />

    <PeriodForecast periods={repPeriods} />

    <SunMoonCard lat={REP_LAT} lon={REP_LON} />

    {areaData && (
      <ObsTable points={areaData.points} areaSlug="valley-west" />
    )}

    {avalancheZones.length > 0 && (
      <section class="mt-8">
        <div class="mb-3 flex items-baseline justify-between">
          <h2 class="text-sm font-semibold uppercase tracking-wider text-amber-500">Avalanche — Neighboring Zones</h2>
          <a href="/avalanche" class="text-xs font-medium text-slate-400 hover:text-amber-400">View all →</a>
        </div>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {avalancheZones.map((z) => <AvalancheCard zone={z} />)}
        </div>
      </section>
    )}

    {!areaData && !error && (
      <p class="py-12 text-center text-sm text-slate-500">
        No data yet — the poller may still be resolving NWS gridpoints.
      </p>
    )}
  </div>
</Layout>
