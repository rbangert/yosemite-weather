---
import Layout from '../layouts/Layout.astro';
import ObsTable from '../components/ObsTable.astro';
import SummaryCard from '../components/SummaryCard.astro';
import { fetchOverview, fetchForecast, fetchLatestObservation } from '../lib/api';
import type { AreaOverview, ForecastRow, ObservationRow } from '../lib/api';

// Yosemite Valley is the canonical representative for the Valley & West area.
const REP_SLUG = 'yosemite-valley';
const REP_NAME = 'Yosemite Valley';

let areaData: AreaOverview | undefined;
let repForecast: ForecastRow[] = [];
let repObservation: ObservationRow | null = null;
let error: string | null = null;

try {
  const [allAreas, forecast, observation] = await Promise.all([
    fetchOverview(),
    fetchForecast(REP_SLUG),
    fetchLatestObservation(REP_SLUG),
  ]);
  areaData = allAreas.find(a => a.slug === 'valley-west');
  repForecast = forecast;
  repObservation = observation;
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to load weather data';
}
---

<Layout title="Valley & West">
  <div class="mx-auto max-w-7xl px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-slate-100">Valley &amp; West</h1>
      <p class="mt-1 text-sm text-slate-400">Current conditions · NOAA/NWS</p>
    </div>

    {error && (
      <div class="mb-6 rounded-lg border border-red-800 bg-red-950 p-4 text-sm text-red-300">
        Could not load weather data: {error}
      </div>
    )}

    <SummaryCard pointName={REP_NAME} observation={repObservation} forecast={repForecast} />

    {areaData && (
      <ObsTable points={areaData.points} areaSlug="valley-west" />
    )}

    {!areaData && !error && (
      <p class="py-12 text-center text-sm text-slate-500">
        No data yet — the poller may still be resolving NWS gridpoints.
      </p>
    )}
  </div>
</Layout>
