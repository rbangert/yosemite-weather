---
import '../styles/global.css';
import AlertsBanner from '../components/AlertsBanner.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
const { pathname } = Astro.url;

const areaLinks = [
  { href: '/', label: 'Valley', active: pathname === '/' || pathname.startsWith('/areas/valley-west') },
  { href: '/areas/south', label: 'South', active: pathname.startsWith('/areas/south') },
  { href: '/areas/high-country', label: 'High Country', active: pathname.startsWith('/areas/high-country') },
  { href: '/snowpack', label: 'Snowpack', active: pathname === '/snowpack' },
  { href: '/data', label: 'Data', active: pathname === '/data' },
];
---

<!doctype html>
<html lang="en" class="bg-slate-950">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Yosemite Weather</title>
  </head>
  <body class="min-h-screen text-slate-100 antialiased">
    <nav class="sticky top-0 z-10 border-b border-slate-800 bg-slate-950/90 backdrop-blur-sm">
      <div class="mx-auto flex h-14 max-w-7xl items-center gap-4 px-4">
        <a href="/" class="flex shrink-0 items-center gap-2 text-slate-100 transition-colors hover:text-amber-400">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="shrink-0 text-amber-400">
            <path d="M3 17l4-8 4 5 3-3 4 6" />
            <path d="M3 20h18" />
          </svg>
          <span class="font-semibold tracking-tight">Yosemite Weather</span>
        </a>

        <div class="h-5 w-px bg-slate-700" />

        <div class="flex items-center gap-1">
          {areaLinks.map(link => (
            <a
              href={link.href}
              class={`rounded-md px-3 py-1.5 text-sm font-medium transition-colors ${
                link.active
                  ? 'bg-slate-800 text-amber-400'
                  : 'text-slate-400 hover:bg-slate-800/60 hover:text-slate-100'
              }`}
            >
              {link.label}
            </a>
          ))}
        </div>

        <div class="ml-auto">
          <button
            id="unit-toggle"
            class="flex items-center gap-0.5 rounded-md border border-slate-700 px-2.5 py-1 text-xs font-medium transition-colors hover:border-slate-500"
            aria-label="Toggle between imperial and metric units"
          >
            <span id="unit-f" class="text-amber-400">°F</span>
            <span class="text-slate-600">/</span>
            <span id="unit-c" class="text-slate-500">°C</span>
          </button>
        </div>
      </div>
    </nav>

    <AlertsBanner />

    <main>
      <slot />
    </main>

    <footer class="mt-16 border-t border-slate-800 py-6 text-center text-sm text-slate-600">
      <div>Data from NOAA/NWS · Updates every 15 minutes</div>
      <div class="mt-2 flex items-center justify-center gap-1.5">
        <span>Built with</span>
        <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 hover:text-slate-400 transition-colors">
          <img src="/logos/astro.svg" alt="Astro" class="h-4 w-auto" />
          <span>Astro</span>
        </a>
        <span>,</span>
        <a href="https://bun.sh" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 hover:text-slate-400 transition-colors">
          <img src="/logos/bun.svg" alt="Bun" class="h-4 w-auto" />
          <span>Bun</span>
        </a>
        <span>, and lots of</span>
        <span>❤️</span>
      </div>
    </footer>
  </body>
</html>

<script>
  const CONVS: Record<string, (v: number, s: string) => string> = {
    temp:         (v, s) => s === 'metric' ? `${Math.round((v - 32) * 5 / 9)}°C`             : `${Math.round(v)}°F`,
    speed:        (v, s) => s === 'metric' ? `${Math.round(v * 1.60934)} km/h`               : `${Math.round(v)} mph`,
    precip:       (v, s) => s === 'metric' ? `${(v * 25.4).toFixed(1)} mm`                  : `${v.toFixed(2)}"`,
    depth:        (v, s) => s === 'metric' ? `${(v * 2.54).toFixed(1)} cm`                  : `${v.toFixed(1)}"`,
    'snow-level': (v, s) => s === 'metric' ? `${Math.round(v * 0.3048).toLocaleString()} m` : `${Math.round(v).toLocaleString()} ft`,
    elevation:    (v, s) => s === 'metric' ? `${Math.round(v * 0.3048).toLocaleString()} m` : `${v.toLocaleString()} ft`,
  };

  function convertWindText(v: string, sys: string): string {
    if (sys === 'imperial') return v;
    const kph = (mph: string) => Math.round(+mph * 1.60934);
    return v.replace(
      /(\d+)\s+to\s+(\d+)\s+mph|(\d+)\s+mph/gi,
      (_, a, b, c) => a ? `${kph(a)} to ${kph(b)} km/h` : `${kph(c)} km/h`,
    );
  }

  function applyUnits(sys: string): void {
    for (const el of document.querySelectorAll<HTMLElement>('[data-unit]')) {
      const fn = CONVS[el.dataset.unit!];
      const val = parseFloat(el.dataset.val!);
      if (fn && !isNaN(val)) el.textContent = fn(val, sys);
    }
    for (const el of document.querySelectorAll<HTMLElement>('[data-unit-text]')) {
      if (el.dataset.unitText === 'wind-text') el.textContent = convertWindText(el.dataset.val!, sys);
    }
    const f = document.getElementById('unit-f');
    const c = document.getElementById('unit-c');
    if (f) f.className = sys === 'imperial' ? 'text-amber-400' : 'text-slate-500';
    if (c) c.className = sys === 'metric'   ? 'text-amber-400' : 'text-slate-500';
    document.dispatchEvent(new CustomEvent('unitschange', { detail: { sys } }));
  }

  let sys = localStorage.getItem('units') ?? 'imperial';
  applyUnits(sys);

  document.getElementById('unit-toggle')?.addEventListener('click', () => {
    sys = sys === 'imperial' ? 'metric' : 'imperial';
    localStorage.setItem('units', sys);
    applyUnits(sys);
  });
</script>
