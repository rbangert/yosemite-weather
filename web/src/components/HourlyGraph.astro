---
import type { ForecastRow } from '../lib/api';

interface Props {
  forecast: ForecastRow[];
  area: string;
}

const { forecast, area } = Astro.props;
if (!forecast.length) return;

const payload = forecast.map(row => ({
  t: row.valid_time,
  temp: row.air_temp,
  dew: row.dewpoint,
  sky: row.sky_cover,
  precip: row.precip_prob,
  thunder: row.thunder_prob,
  wind: row.wind_speed,
  gust: row.wind_gust,
  dir: row.wind_direction,
  rh: row.relative_humidity,
  snowLvl: row.snow_level,
}));

// Wind direction arrows: rendered server-side, one per entry, shown every 6th
// Arrow "↑" is rotated to point into the wind (meteorological convention: dir=0 = from N = up)
function arrowStyle(deg: number | null): string | null {
  if (deg === null) return null;
  return `transform:rotate(${Math.round(deg)}deg);display:inline-block`;
}
---

<div id="hourly-graph" data-forecast={JSON.stringify(payload)} data-area={area}>
  <!-- Legend -->
  <div class="flex flex-wrap gap-x-4 gap-y-0.5 px-1 pb-2 pt-1 text-[11px] text-slate-500">
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-0.5 w-4 bg-[#FFB86C]"></span>Temp
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block w-4 border-t border-dashed border-[#50FA7B]"></span>Dewpoint
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-2 w-3 rounded-sm" style="background:rgba(98,114,164,0.6)"></span>Cloud
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-2 w-3 rounded-sm" style="background:rgba(139,233,253,0.5)"></span>Precip%
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-2 w-3 rounded-sm" style="background:rgba(255,184,108,0.55)"></span>Thunder%
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block h-2 w-3 rounded-sm" style="background:rgba(80,250,123,0.35)"></span>Wind
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block w-4 border-t border-dashed border-[#6272A4]"></span>Humidity
    </span>
  </div>

  <div class="overflow-x-auto">
    <div class="min-w-[680px]">

      <!-- Panel 1: Temperature + Dewpoint -->
      <div class="relative" style="height:150px">
        <canvas id="hg-temp"></canvas>
      </div>

      <!-- Panel 2: Sky Cover (color-coded bars) -->
      <div class="relative" style="height:56px">
        <canvas id="hg-sky"></canvas>
      </div>

      <!-- Panel 3: Precipitation % + Thunder % -->
      <div class="relative" style="height:80px">
        <canvas id="hg-precip"></canvas>
      </div>

      <!-- Panel 4: Wind Speed / Gust + Humidity (x-axis labels here) -->
      <div class="relative" style="height:110px">
        <canvas id="hg-wind"></canvas>
      </div>

      <!-- Wind direction strip: rotated ↑ arrows -->
      <div class="flex mt-0.5 select-none" aria-hidden="true">
        {payload.map((pt, i) => (
          <span class="flex-1 flex items-center justify-center" style="height:14px">
            {i % 6 === 0 && pt.dir !== null
              ? <span class="text-[9px] text-slate-500" style={arrowStyle(pt.dir) ?? ''}>↑</span>
              : ''}
          </span>
        ))}
      </div>

    </div>
  </div>
</div>

<script>
  import {
    Chart,
    LineController,
    BarController,
    LineElement,
    BarElement,
    PointElement,
    LinearScale,
    CategoryScale,
    Tooltip,
    Filler,
  } from 'chart.js';

  Chart.register(
    LineController, BarController, LineElement, BarElement,
    PointElement, LinearScale, CategoryScale, Tooltip, Filler,
  );

  type Row = {
    t: string;
    temp: number | null; dew: number | null; sky: number | null;
    precip: number | null; thunder: number | null;
    wind: number | null; gust: number | null; dir: number | null;
    rh: number | null; snowLvl: number | null;
  };

  const wrapper = document.getElementById('hourly-graph') as HTMLDivElement | null;
  if (wrapper) {
    const raw: Row[] = JSON.parse(wrapper.dataset.forecast!);
    const isHighCountry = wrapper.dataset.area === 'high-country';

    const toC  = (f: number | null): number | null => f !== null ? Math.round((f - 32) * 5 / 9) : null;
    const toKh = (m: number | null): number | null => m !== null ? Math.round(m * 1.60934) : null;
    const toM  = (f: number | null): number | null => f !== null ? Math.round(f * 0.3048) : null;

    let currentSys = localStorage.getItem('units') ?? 'imperial';

    const getTemps  = () => currentSys === 'metric' ? raw.map(r => toC(r.temp))    : raw.map(r => r.temp);
    const getDews   = () => currentSys === 'metric' ? raw.map(r => toC(r.dew))     : raw.map(r => r.dew);
    const getWinds  = () => currentSys === 'metric' ? raw.map(r => toKh(r.wind))   : raw.map(r => r.wind);
    const getGusts  = () => currentSys === 'metric' ? raw.map(r => toKh(r.gust))   : raw.map(r => r.gust);
    const getSnow   = () => currentSys === 'metric' ? raw.map(r => toM(r.snowLvl)) : raw.map(r => r.snowLvl);

    const labels = raw.map(r =>
      new Date(r.t).toLocaleString('en-US', { weekday: 'short', hour: 'numeric', hour12: true }),
    );

    const GRID = 'rgba(148,163,184,0.08)';
    const TT = {
      backgroundColor: '#282A36',
      borderColor: '#44475A',
      borderWidth: 1,
      titleColor: '#F8F8F2',
      bodyColor: '#ABB2BF',
      padding: 8,
    } as const;

    let chartTemp: Chart | undefined;
    let chartWind: Chart | undefined;

    document.addEventListener('ft-hourly-activate', () => {
      if (chartTemp) return;

      // Dashed "now" marker shared across panels
      const nowLinePlugin = {
        id: 'nowLine',
        afterDraw(chart: Chart) {
          const now = Date.now();
          const idx = raw.findIndex((r, i) => {
            const t = new Date(r.t).getTime();
            const next = raw[i + 1];
            return t <= now && (!next || new Date(next.t).getTime() > now);
          });
          if (idx < 0) return;
          const pt = chart.getDatasetMeta(0).data[idx];
          if (!pt) return;
          const { ctx, chartArea } = chart;
          ctx.save();
          ctx.strokeStyle = 'rgba(248,248,242,0.18)';
          ctx.lineWidth = 1;
          ctx.setLineDash([4, 4]);
          ctx.beginPath();
          ctx.moveTo(pt.x, chartArea.top);
          ctx.lineTo(pt.x, chartArea.bottom);
          ctx.stroke();
          ctx.restore();
        },
      };

      // ── Panel 1: Temperature + Dewpoint ─────────────────────────────────────
      const cTemp = document.getElementById('hg-temp') as HTMLCanvasElement;

      const tempDs: any[] = [
        {
          type: 'line',
          label: currentSys === 'metric' ? 'Temp (°C)' : 'Temp (°F)',
          data: getTemps(),
          fill: true,
          borderColor: '#FFB86C',
          backgroundColor: 'rgba(255,184,108,0.15)',
          borderWidth: 2,
          pointRadius: 0,
          tension: 0.4,
          spanGaps: true,
          yAxisID: 'yTemp',
          order: 2,
        },
        {
          type: 'line',
          label: currentSys === 'metric' ? 'Dewpoint (°C)' : 'Dewpoint (°F)',
          data: getDews(),
          fill: false,
          borderColor: '#50FA7B',
          borderDash: [5, 3],
          borderWidth: 1.5,
          pointRadius: 0,
          tension: 0.4,
          spanGaps: true,
          yAxisID: 'yTemp',
          order: 1,
        } as any,
      ];

      if (isHighCountry) {
        tempDs.push({
          type: 'line',
          label: currentSys === 'metric' ? 'Snow Level (m)' : 'Snow Level (ft)',
          data: getSnow(),
          fill: false,
          borderColor: '#8BE9FD',
          borderDash: [5, 3],
          borderWidth: 1.5,
          pointRadius: 0,
          tension: 0.3,
          spanGaps: true,
          yAxisID: 'ySnow',
        } as any);
      }

      const tempScales: any = {
        x: { grid: { color: GRID }, border: { display: false }, ticks: { display: false } },
        yTemp: {
          position: 'left',
          grid: { color: GRID },
          border: { display: false },
          ticks: { color: '#FFB86C', maxTicksLimit: 5, callback: (v: any) => `${v}°` },
        },
      };
      if (isHighCountry) {
        tempScales.ySnow = {
          position: 'right',
          grid: { drawOnChartArea: false },
          border: { display: false },
          ticks: {
            color: '#8BE9FD',
            maxTicksLimit: 4,
            callback: (v: any) => v >= 1000
              ? `${(v / 1000).toFixed(1)}k${currentSys === 'metric' ? 'm' : ''}`
              : `${v}${currentSys === 'metric' ? 'm' : ''}`,
          },
        };
      }

      chartTemp = new Chart(cTemp, {
        data: { labels, datasets: tempDs },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          interaction: { mode: 'index', intersect: false },
          scales: tempScales,
          plugins: {
            legend: { display: false },
            tooltip: {
              ...TT,
              callbacks: {
                label: ctx => {
                  const v = ctx.raw as number | null;
                  if (v === null) return '';
                  const lbl = ctx.dataset.label ?? '';
                  if (lbl.includes('Snow')) return `Snow Level: ${Math.round(v).toLocaleString()}${currentSys === 'metric' ? ' m' : ' ft'}`;
                  const unit = currentSys === 'metric' ? '°C' : '°F';
                  return `${lbl.split(' (')[0]}: ${Math.round(v)}${unit}`;
                },
              },
            },
          },
        },
        plugins: [nowLinePlugin],
      });

      // ── Panel 2: Sky Cover (color-coded bars — dark = overcast) ─────────────
      const cSky = document.getElementById('hg-sky') as HTMLCanvasElement;

      // Bar color opacity scales with cloud coverage (clear = faint, overcast = solid)
      const skyColors = raw.map(r => {
        const pct = (r.sky ?? 0) / 100;
        return `rgba(98,114,164,${(0.08 + pct * 0.72).toFixed(2)})`;
      });

      const chartSky = new Chart(cSky, {
        data: {
          labels,
          datasets: [{
            type: 'bar',
            label: 'Cloud Cover',
            data: raw.map(() => 100), // full-height bars; color encodes coverage
            backgroundColor: skyColors,
            borderWidth: 0,
            categoryPercentage: 1.0,
            barPercentage: 1.0,
          }],
        },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          interaction: { mode: 'index', intersect: false },
          scales: {
            x: { grid: { display: false }, border: { display: false }, ticks: { display: false } },
            y: {
              min: 0, max: 100,
              grid: { display: false }, border: { display: false },
              ticks: { display: false },
            },
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              ...TT,
              callbacks: {
                label: ctx => {
                  const idx = ctx.dataIndex;
                  return `Cloud: ${Math.round(raw[idx]?.sky ?? 0)}%`;
                },
              },
            },
          },
        },
        plugins: [nowLinePlugin],
      });

      // ── Panel 3: Precip % + Thunder % ───────────────────────────────────────
      const cPrecip = document.getElementById('hg-precip') as HTMLCanvasElement;

      const chartPrecip = new Chart(cPrecip, {
        data: {
          labels,
          datasets: [
            {
              type: 'bar',
              label: 'Precip %',
              data: raw.map(r => r.precip),
              backgroundColor: 'rgba(139,233,253,0.45)',
              borderColor: 'rgba(139,233,253,0.7)',
              borderWidth: 1,
              categoryPercentage: 0.95,
              yAxisID: 'y',
              order: 2,
            },
            {
              type: 'bar',
              label: 'Thunder %',
              data: raw.map(r => r.thunder),
              backgroundColor: 'rgba(255,184,108,0.5)',
              borderColor: 'rgba(255,184,108,0.75)',
              borderWidth: 1,
              categoryPercentage: 0.95,
              yAxisID: 'y',
              order: 1,
            },
          ],
        },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          interaction: { mode: 'index', intersect: false },
          scales: {
            x: { grid: { color: GRID }, border: { display: false }, ticks: { display: false } },
            y: {
              min: 0, max: 100,
              position: 'left',
              grid: { color: GRID }, border: { display: false },
              ticks: { color: '#8BE9FD', maxTicksLimit: 3, callback: v => `${v}%` },
            },
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              ...TT,
              callbacks: {
                label: ctx => {
                  const v = ctx.raw as number | null;
                  if (v === null || v === 0) return '';
                  return `${ctx.dataset.label}: ${Math.round(v)}%`;
                },
              },
            },
          },
        },
        plugins: [nowLinePlugin],
      });

      // ── Panel 4: Wind + Humidity ─────────────────────────────────────────────
      const cWind = document.getElementById('hg-wind') as HTMLCanvasElement;

      chartWind = new Chart(cWind, {
        data: {
          labels,
          datasets: [
            {
              type: 'line',
              label: 'Wind',
              data: getWinds(),
              fill: true,
              borderColor: '#50FA7B',
              backgroundColor: 'rgba(80,250,123,0.18)',
              borderWidth: 1.5,
              pointRadius: 0,
              tension: 0.4,
              spanGaps: true,
              yAxisID: 'yWind',
            },
            {
              type: 'line',
              label: 'Gust',
              data: getGusts(),
              fill: false,
              borderColor: 'rgba(80,250,123,0.45)',
              borderDash: [4, 3],
              borderWidth: 1,
              pointRadius: 0,
              tension: 0.4,
              spanGaps: true,
              yAxisID: 'yWind',
            } as any,
            {
              type: 'line',
              label: 'Humidity',
              data: raw.map(r => r.rh),
              fill: false,
              borderColor: 'rgba(98,114,164,0.7)',
              borderDash: [4, 4],
              borderWidth: 1.5,
              pointRadius: 0,
              tension: 0.4,
              spanGaps: true,
              yAxisID: 'yRH',
            } as any,
          ],
        },
        options: {
          responsive: true, maintainAspectRatio: false, animation: false,
          interaction: { mode: 'index', intersect: false },
          scales: {
            x: {
              grid: { color: GRID }, border: { display: false },
              ticks: {
                color: '#6272A4',
                maxRotation: 0,
                autoSkip: false,
                callback: (_val: any, index: number) => {
                  if (!raw[index]) return '';
                  const h = new Date(raw[index].t).getHours();
                  return h % 6 === 0 ? labels[index] : '';
                },
              },
            },
            yWind: {
              position: 'left', min: 0,
              grid: { color: GRID }, border: { display: false },
              ticks: {
                color: '#50FA7B', maxTicksLimit: 4,
                callback: (v: any) => currentSys === 'metric' ? `${v}km/h` : `${v}mph`,
              },
            },
            yRH: {
              position: 'right', min: 0, max: 100,
              grid: { drawOnChartArea: false }, border: { display: false },
              ticks: { color: '#6272A4', maxTicksLimit: 3, callback: (v: any) => `${v}%` },
            },
          },
          plugins: {
            legend: { display: false },
            tooltip: {
              ...TT,
              callbacks: {
                label: ctx => {
                  const v = ctx.raw as number | null;
                  if (v === null) return '';
                  if (ctx.dataset.label === 'Humidity') return `RH: ${Math.round(v)}%`;
                  const unit = currentSys === 'metric' ? 'km/h' : 'mph';
                  return `${ctx.dataset.label}: ${Math.round(v)} ${unit}`;
                },
              },
            },
          },
        },
        plugins: [nowLinePlugin],
      });

      // ── Cross-chart tooltip sync ───────────────────────────────────────────
      const allCharts = [chartTemp, chartSky, chartPrecip, chartWind];
      allCharts.forEach(src => {
        src.canvas.addEventListener('mousemove', e => {
          const pts = src.getElementsAtEventForMode(e, 'index', { intersect: false }, true);
          if (!pts.length) return;
          const idx = pts[0].index;
          allCharts.forEach(c => {
            if (c === src) return;
            const active = c.data.datasets.map((_, di) => ({ datasetIndex: di, index: idx }));
            c.tooltip!.setActiveElements(active, { x: 0, y: 0 });
            c.update('active');
          });
        });
        src.canvas.addEventListener('mouseleave', () => {
          allCharts.forEach(c => {
            c.tooltip!.setActiveElements([], { x: 0, y: 0 });
            c.update('active');
          });
        });
      });
    });

    // ── Unit conversion ──────────────────────────────────────────────────────
    document.addEventListener('unitschange', e => {
      currentSys = (e as CustomEvent<{ sys: string }>).detail.sys;
      if (!chartTemp || !chartWind) return;

      chartTemp.data.datasets[0].data = getTemps();
      (chartTemp.data.datasets[0] as any).label = currentSys === 'metric' ? 'Temp (°C)' : 'Temp (°F)';
      chartTemp.data.datasets[1].data = getDews();
      (chartTemp.data.datasets[1] as any).label = currentSys === 'metric' ? 'Dewpoint (°C)' : 'Dewpoint (°F)';
      if (isHighCountry && chartTemp.data.datasets[2]) {
        chartTemp.data.datasets[2].data = getSnow();
        (chartTemp.data.datasets[2] as any).label = currentSys === 'metric' ? 'Snow Level (m)' : 'Snow Level (ft)';
      }
      chartTemp.update('none');

      chartWind.data.datasets[0].data = getWinds();
      chartWind.data.datasets[1].data = getGusts();
      chartWind.update('none');
    });
  }
</script>
