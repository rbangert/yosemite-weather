---
import type { PeriodForecastRow } from '../lib/api';
import { nwsIcon } from '../lib/nwsIcons';

interface Props {
  periods: PeriodForecastRow[];
}

const { periods } = Astro.props;
if (!periods.length) return;

function tempColor(t: number | null): string {
  if (t === null) return 'text-slate-500';
  if (t < 32)  return 'text-blue-300';
  if (t < 45)  return 'text-sky-300';
  if (t < 60)  return 'text-emerald-300';
  if (t < 72)  return 'text-amber-200';
  if (t < 85)  return 'text-orange-300';
  return 'text-red-400';
}

const WIND_DIR_ICON: Record<string, string> = {
  'N':   'wi-wind-north',
  'NNE': 'wi-wind-north-east',
  'NE':  'wi-wind-north-east',
  'ENE': 'wi-wind-east',
  'E':   'wi-wind-east',
  'ESE': 'wi-wind-south-east',
  'SE':  'wi-wind-south-east',
  'SSE': 'wi-wind-south',
  'S':   'wi-wind-south',
  'SSW': 'wi-wind-south-west',
  'SW':  'wi-wind-south-west',
  'WSW': 'wi-wind-west',
  'W':   'wi-wind-west',
  'WNW': 'wi-wind-north-west',
  'NW':  'wi-wind-north-west',
  'NNW': 'wi-wind-north',
};

// Alternating background per day-group (each day + night pair = one group).
function groupIndex(i: number): number {
  let g = 0;
  for (let j = 0; j < i; j++) {
    if (periods[j].is_daytime && j + 1 < periods.length && !periods[j + 1].is_daytime) g++;
  }
  return g;
}
---

<div class="mb-6 overflow-hidden rounded-xl border border-slate-800 bg-slate-900">
  <div class="border-b border-slate-800 px-6 py-4">
    <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400">7-Day Forecast</h2>
  </div>

  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-800 text-xs font-medium uppercase tracking-wide text-slate-500">
          <th class="px-4 py-3 text-left">Period</th>
          <th class="px-3 py-3 text-left">Conditions</th>
          <th class="px-4 py-3 text-right">Temp</th>
          <th class="hidden px-4 py-3 text-left sm:table-cell">Wind</th>
          <th class="px-4 py-3 text-right">Precip</th>
        </tr>
      </thead>
      <tbody>
        {periods.map((row, i) => {
          const isDay = row.is_daytime === 1;
          const g = groupIndex(i);
          const rowBg = isDay
            ? (g % 2 === 0 ? '' : 'bg-slate-800/20')
            : (g % 2 === 0 ? 'bg-slate-800/30' : 'bg-slate-800/50');
          const { wiClass, colorClass } = nwsIcon(row.icon_url, isDay);
          const precip = row.precip_prob ?? 0;
          const tColor = tempColor(row.temperature);

          return (
            <tr class={`border-b border-slate-800/40 ${rowBg}`}>
              <td class="whitespace-nowrap px-4 py-2.5">
                <span class={`font-medium ${isDay ? 'text-slate-200' : 'text-slate-400'}`}>
                  {row.name}
                </span>
              </td>
              <td class="px-3 py-2.5">
                <div class="flex items-center gap-3">
                  <i class={`${wiClass} ${colorClass} w-6 text-center text-xl leading-none`} aria-hidden="true" />
                  <span class="text-slate-300">{row.short_forecast ?? '—'}</span>
                </div>
              </td>
              <td class={`px-4 py-2.5 text-right tabular-nums font-semibold ${tColor}`}>
                {row.temperature !== null
                  ? <span data-unit="temp" data-val={row.temperature}>{row.temperature}°F</span>
                  : '—'}
              </td>
              <td class="hidden whitespace-nowrap px-4 py-2.5 text-slate-400 sm:table-cell">
                {row.wind_speed && row.wind_direction
                  ? <span class="flex items-center gap-1.5">
                      {WIND_DIR_ICON[row.wind_direction] && (
                        <i class={`wi ${WIND_DIR_ICON[row.wind_direction]} text-2xl leading-none text-white`} aria-hidden="true" />
                      )}
                      {row.wind_direction} <span data-unit-text="wind-text" data-val={row.wind_speed}>{row.wind_speed}</span>
                    </span>
                  : (row.wind_speed
                      ? <span data-unit-text="wind-text" data-val={row.wind_speed}>{row.wind_speed}</span>
                      : '—')}
              </td>
              <td class={`px-4 py-2.5 text-right tabular-nums ${precip >= 20 ? 'text-blue-400' : 'text-slate-600'}`}>
                {precip > 0 ? `${Math.round(precip)}%` : '—'}
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</div>
