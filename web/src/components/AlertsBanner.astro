---
import { fetchAlerts, type AlertRow } from '../lib/api';

const alerts = await fetchAlerts();
if (alerts.length === 0) return;

function severityClasses(severity: string): { banner: string; badge: string } {
  switch (severity) {
    case 'Extreme':
      return { banner: 'border-red-800 bg-red-950/70', badge: 'bg-red-600 text-white' };
    case 'Severe':
      return { banner: 'border-red-700 bg-red-950/60', badge: 'bg-red-500 text-white' };
    case 'Moderate':
      return { banner: 'border-orange-700 bg-orange-950/60', badge: 'bg-orange-500 text-white' };
    case 'Minor':
      return { banner: 'border-yellow-700 bg-yellow-950/60', badge: 'bg-yellow-500 text-black' };
    default:
      return { banner: 'border-slate-700 bg-slate-800/60', badge: 'bg-slate-600 text-slate-200' };
  }
}

function isFireEvent(event: string): boolean {
  return /fire|red flag/i.test(event);
}

function formatTime(iso: string | null): string {
  if (!iso) return '';
  return new Date(iso).toLocaleString('en-US', {
    month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit',
    timeZoneName: 'short',
  });
}
---

<div class="border-b border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-7xl space-y-2 px-4 py-3">
    {alerts.map((alert: AlertRow) => {
      const { banner, badge } = severityClasses(alert.severity);
      const fire = isFireEvent(alert.event);
      const expires = alert.ends ?? alert.expires;
      return (
        <details class={`group rounded-md border ${banner} text-sm`}>
          <summary class="flex cursor-pointer list-none items-start gap-3 px-3 py-2">
            <span class="mt-0.5 shrink-0 text-base leading-none" aria-hidden="true">
              {fire ? '🔥' : '⚠️'}
            </span>
            <span class="min-w-0 flex-1">
              <span class={`mr-2 inline-block rounded px-1.5 py-0.5 text-xs font-semibold uppercase tracking-wide ${badge}`}>
                {alert.severity}
              </span>
              <span class="font-semibold text-slate-100">{alert.event}</span>
              {alert.headline && (
                <span class="ml-1 text-slate-300"> — {alert.headline}</span>
              )}
            </span>
            <svg
              class="mt-1 h-4 w-4 shrink-0 text-slate-400 transition-transform group-open:rotate-180"
              viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            >
              <path d="M6 9l6 6 6-6" />
            </svg>
          </summary>

          <div class="border-t border-slate-700/50 px-3 py-3 text-slate-300">
            {alert.description && (
              <p class="whitespace-pre-wrap text-xs leading-relaxed">{alert.description}</p>
            )}
            {alert.instruction && (
              <p class="mt-2 whitespace-pre-wrap text-xs leading-relaxed text-amber-300">
                <strong class="font-semibold">What to do:</strong> {alert.instruction}
              </p>
            )}
            <p class="mt-2 text-xs text-slate-500">
              Expires {formatTime(expires)}
              {alert.area_desc && <span> · {alert.area_desc}</span>}
            </p>
          </div>
        </details>
      );
    })}
  </div>
</div>
