---
import type { AvalancheZoneSummary } from '../lib/api';
import { dangerInfo, formatDateTime } from '../lib/avalanche';

interface Props {
  zone: AvalancheZoneSummary;
  /** Link to the in-app detail view instead of the external center. */
  href?: string;
}

const { zone, href = `/avalanche?zone=${zone.centerId}` } = Astro.props;

const hasForecast = zone.offSeason === false && zone.dangerLevel > 0;
const info = dangerInfo(zone.dangerLevel);
---

<a
  href={href}
  class="block rounded-xl border border-slate-800 bg-slate-900 p-4 transition-colors hover:border-slate-600"
>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <div class="truncate text-sm font-semibold text-slate-100">{zone.name}</div>
      <div class="mt-0.5 text-[11px] text-slate-500">{zone.relation}</div>
    </div>
    <span class="shrink-0 text-[10px] font-medium uppercase tracking-wider text-slate-500">{zone.centerId}</span>
  </div>

  <div class="mt-3 flex items-center gap-2.5">
    <span
      class="flex h-9 w-9 shrink-0 items-center justify-center rounded-md text-sm font-bold"
      style={`background:${info.bg};color:${info.text}`}
    >{hasForecast ? zone.dangerLevel : '—'}</span>
    <div class="min-w-0">
      {hasForecast ? (
        <>
          <div class="text-sm font-semibold text-slate-100">{info.label}</div>
          <div class="text-[11px] text-slate-500">Expires {formatDateTime(zone.expiresTime)}</div>
        </>
      ) : (
        <>
          <div class="text-sm font-medium text-slate-300">No active forecast</div>
          <div class="text-[11px] text-slate-500">
            {zone.fetchedAt ? 'Off-season' : 'Awaiting data'}
          </div>
        </>
      )}
    </div>
  </div>
</a>
