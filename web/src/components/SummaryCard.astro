---
import type { ForecastRow, ObservationRow } from '../lib/api';
import { getHolidaysForDate } from '../lib/holidays';

interface Props {
  pointName: string;
  observation: ObservationRow | null;
  forecast: ForecastRow[];
}

const { pointName, observation, forecast } = Astro.props;

// --- Pacific-time date for holiday detection (all locations are in California) ---
const dtf = new Intl.DateTimeFormat('en-US', {
  timeZone: 'America/Los_Angeles',
  year: 'numeric', month: '2-digit', day: '2-digit',
  hour: 'numeric', hour12: false,
});
const parts = dtf.formatToParts(new Date());
const get = (t: string) => parts.find(p => p.type === t)?.value ?? '0';
const pacificHour = parseInt(get('hour'));
const localDate = new Date(parseInt(get('year')), parseInt(get('month')) - 1, parseInt(get('day')));

const holidays = getHolidaysForDate(localDate);
const isDay = pacificHour >= 6 && pacificHour < 18;

// --- Helper functions ---

function windDir16(deg: number | null): string {
  if (deg === null) return '';
  const dirs = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
  return dirs[Math.round(deg / 22.5) % 16];
}

function skyDesc(cover: number | null, day: boolean): string {
  if (cover === null) return 'variable clouds';
  if (cover < 12)  return day ? 'sunny' : 'clear';
  if (cover < 25)  return day ? 'mostly sunny' : 'mostly clear';
  if (cover < 50)  return day ? 'partly sunny' : 'partly cloudy';
  if (cover < 75)  return 'mostly cloudy';
  return 'overcast';
}

function currentWindSentence(speed: number | null, dir: number | null, gust: number | null): string {
  if (!speed || speed < 3) return 'Calm.';
  const d = windDir16(dir);
  let s = `Winds ${Math.round(speed)} mph ${d}`;
  if (gust !== null && gust > speed + 5) s += `, gusting to ${Math.round(gust)} mph`;
  return s + '.';
}

function forecastWindSentence(speed: number, dir: number | null, gust: number): string {
  if (speed < 3) return 'Light and variable winds.';
  const d = windDir16(dir);
  let s = speed < 7 ? `Light ${d} winds around ${Math.round(speed)} mph` : `${d} winds ${Math.round(speed)} mph`;
  if (gust > speed + 5) s += `, gusting to ${Math.round(gust)} mph`;
  return s + '.';
}

// --- Current conditions prose ---
const condSentences: string[] = [];

if (observation) {
  const time = new Date(observation.observed_at).toLocaleString('en-US', {
    hour: 'numeric', minute: '2-digit',
    timeZone: 'America/Los_Angeles', timeZoneName: 'short',
  });
  const temp = observation.air_temp !== null ? `${Math.round(observation.air_temp)}°F` : '—';
  condSentences.push(`At ${time}, the temperature in ${pointName} was ${temp}.`);
  condSentences.push(currentWindSentence(observation.wind_speed, observation.wind_direction, observation.wind_gust));

  if (observation.precip_last_hour !== null && observation.precip_last_hour > 0.005) {
    const p = observation.precip_last_hour;
    condSentences.push(`Precipitation: ${p < 0.01 ? 'Trace' : `${p.toFixed(2)}"`} last hour.`);
  }

  if (observation.snow_depth !== null && observation.snow_depth > 0) {
    condSentences.push(`Snow depth: ${observation.snow_depth.toFixed(1)}".`);
  }
} else if (forecast.length > 0) {
  // Fall back to current forecast row when no observation is available
  const cur = forecast[0];
  const temp = cur.air_temp !== null ? `${Math.round(cur.air_temp)}°F` : '—';
  condSentences.push(`Current forecast for ${pointName}: ${temp}.`);
  condSentences.push(currentWindSentence(cur.wind_speed, cur.wind_direction, cur.wind_gust));
}

// --- Period label (Pacific time) ---
let periodLabel: string;
if      (pacificHour >= 6  && pacificHour < 12) periodLabel = 'This morning';
else if (pacificHour >= 12 && pacificHour < 18) periodLabel = 'This afternoon';
else if (pacificHour >= 18)                      periodLabel = 'Tonight';
else                                             periodLabel = 'Early this morning';

// --- Forecast prose (next 12 hours) ---
const fcstSentences: string[] = [];
const next12 = forecast.slice(0, 12);

if (next12.length > 0) {
  const validSky   = next12.map(r => r.sky_cover).filter((v): v is number => v !== null);
  const avgSky     = validSky.length ? validSky.reduce((a, b) => a + b, 0) / validSky.length : null;

  const validTemps = next12.map(r => r.air_temp).filter((v): v is number => v !== null);
  const minT       = validTemps.length ? Math.min(...validTemps) : null;
  const maxT       = validTemps.length ? Math.max(...validTemps) : null;
  const keyTemp    = isDay ? maxT : minT;
  const tempLabel  = isDay ? 'high' : 'low';

  const maxPrecipProb = Math.max(0, ...next12.map(r => r.precip_prob ?? 0));
  const maxWind       = Math.max(0, ...next12.map(r => r.wind_speed ?? 0));
  const maxGust       = Math.max(0, ...next12.map(r => r.wind_gust ?? 0));
  const peakRow       = next12.reduce((best, r) => (r.wind_speed ?? 0) > (best.wind_speed ?? 0) ? r : best, next12[0]);
  const totalSnow     = next12.reduce((sum, r) => sum + (r.snowfall_amount ?? 0), 0);

  let line1 = `${periodLabel} will be ${skyDesc(avgSky, isDay)}`;
  if (keyTemp !== null) line1 += `, with a ${tempLabel} around ${Math.round(keyTemp)}°F`;
  line1 += '.';
  fcstSentences.push(line1);

  if (maxWind >= 3) {
    fcstSentences.push(forecastWindSentence(maxWind, peakRow.wind_direction, maxGust));
  }

  if (maxPrecipProb >= 10) {
    const precipType = minT !== null && minT < 32 ? 'snow' :
                       minT !== null && minT < 34 ? 'wintry mix' : 'precipitation';
    fcstSentences.push(`${Math.round(maxPrecipProb)}% chance of ${precipType}.`);
  }

  if (totalSnow >= 0.1) {
    fcstSentences.push(`Possible snowfall: up to ${totalSnow.toFixed(1)}" expected.`);
  }
}

const hasContent = condSentences.length > 0 || fcstSentences.length > 0;
---

<div class="mb-6 overflow-hidden rounded-xl border border-slate-800 bg-slate-900">
  {holidays.length > 0 && (
    <div class="border-b border-amber-800/40 bg-amber-950/40 px-6 py-3">
      <span class="text-sm font-semibold text-amber-400">It's {holidays[0]}!</span>
    </div>
  )}

  <div class="p-6">
    <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400">
      Summary
    </h2>

    {hasContent ? (
      <div class="space-y-3">
        {condSentences.length > 0 && (
          <p class="leading-relaxed text-slate-200">
            {condSentences.join(' ')}
          </p>
        )}
        {fcstSentences.length > 0 && (
          <>
            {condSentences.length > 0 && <div class="border-t border-slate-800" />}
            <p class="leading-relaxed text-slate-300">
              {fcstSentences.join(' ')}
            </p>
          </>
        )}
      </div>
    ) : (
      <p class="text-sm text-slate-500">No weather data available yet.</p>
    )}
  </div>
</div>
