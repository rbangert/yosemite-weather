---
import type { ForecastRow, ObservationRow, PeriodForecastRow, ForecastDiscussion } from '../lib/api';
import { getHolidaysForDate } from '../lib/holidays';
import { nwsIcon } from '../lib/nwsIcons';
import { getSunData, getMoonData, formatPacific, formatDayLength } from '../lib/sunMoon';

interface Props {
  pointName: string;
  observation: ObservationRow | null;
  forecast: ForecastRow[];
  periods?: PeriodForecastRow[];
  discussion?: ForecastDiscussion | null;
  lat: number;
  lon: number;
}

const { pointName, observation, forecast, periods = [], discussion = null, lat, lon } = Astro.props;

// --- Pacific-time date for holiday detection (all locations are in California) ---
const dtf = new Intl.DateTimeFormat('en-US', {
  timeZone: 'America/Los_Angeles',
  year: 'numeric', month: '2-digit', day: '2-digit',
  hour: 'numeric', hour12: false,
});
const parts = dtf.formatToParts(new Date());
const get = (t: string) => parts.find(p => p.type === t)?.value ?? '0';
const localDate = new Date(parseInt(get('year')), parseInt(get('month')) - 1, parseInt(get('day')));

const holidays = getHolidaysForDate(localDate);

// --- Helper functions ---

function windDir16(deg: number | null): string {
  if (deg === null) return '';
  const dirs = ['N','NNE','NE','ENE','E','ESE','SE','SSE','S','SSW','SW','WSW','W','WNW','NW','NNW'];
  return dirs[Math.round(deg / 22.5) % 16];
}

function currentWindSentence(speed: number | null, dir: number | null, gust: number | null): string {
  if (!speed || speed < 3) return 'Calm.';
  const d = windDir16(dir);
  let s = `Winds ${Math.round(speed)} mph ${d}`;
  if (gust !== null && gust > speed + 5) s += `, gusting to ${Math.round(gust)} mph`;
  return s + '.';
}

// --- Current conditions prose (live observation) ---
const condSentences: string[] = [];

if (observation) {
  const time = new Date(observation.observed_at).toLocaleString('en-US', {
    hour: 'numeric', minute: '2-digit',
    timeZone: 'America/Los_Angeles', timeZoneName: 'short',
  });
  const temp = observation.air_temp !== null ? `${Math.round(observation.air_temp)}°F` : '—';
  condSentences.push(`At ${time}, the temperature in ${pointName} was ${temp}.`);
  condSentences.push(currentWindSentence(observation.wind_speed, observation.wind_direction, observation.wind_gust));

  if (observation.precip_last_hour !== null && observation.precip_last_hour > 0.005) {
    const p = observation.precip_last_hour;
    condSentences.push(`Precipitation: ${p < 0.01 ? 'Trace' : `${p.toFixed(2)}"`} last hour.`);
  }

  if (observation.snow_depth !== null && observation.snow_depth > 0) {
    condSentences.push(`Snow depth: ${observation.snow_depth.toFixed(1)}".`);
  }
} else if (forecast.length > 0) {
  // Fall back to current forecast row when no observation is available.
  const cur = forecast[0];
  const temp = cur.air_temp !== null ? `${Math.round(cur.air_temp)}°F` : '—';
  condSentences.push(`Current forecast for ${pointName}: ${temp}.`);
  condSentences.push(currentWindSentence(cur.wind_speed, cur.wind_direction, cur.wind_gust));
}

// --- NWS worded forecast (first few future periods) ---
const wordedPeriods = periods
  .filter(p => p.detailed_forecast && p.detailed_forecast.trim().length > 0)
  .slice(0, 4);

// --- Sun & Moon (compact) ---
const sun = getSunData(new Date(), lat, lon);
const moon = getMoonData(new Date(), lat, lon);

// --- Area Forecast Discussion: split into .SECTION... blocks ---
interface AfdSection { name: string; body: string; }

function parseAfd(text: string): AfdSection[] {
  const headerRe = /^\.([A-Z][A-Z0-9 .\/&'-]*?)\.\.\./gm;
  const heads: { name: string; start: number; bodyStart: number }[] = [];
  let m: RegExpExecArray | null;
  while ((m = headerRe.exec(text)) !== null) {
    heads.push({ name: m[1].trim(), start: m.index, bodyStart: m.index + m[0].length });
  }
  return heads.map((h, i) => {
    const end = i + 1 < heads.length ? heads[i + 1].start : text.length;
    const body = text.slice(h.bodyStart, end)
      .replace(/^\s*(&&|\$\$)\s*$/gm, '') // drop section/product terminators
      .trim();
    return { name: h.name, body };
  }).filter(s => s.body.length > 0);
}

const afdSections = discussion ? parseAfd(discussion.product_text) : [];
const synopsis = afdSections.find(s => s.name === 'SYNOPSIS') ?? afdSections[0] ?? null;
const afdIssued = discussion?.issuance_time
  ? new Date(discussion.issuance_time).toLocaleString('en-US', {
      month: 'short', day: 'numeric', hour: 'numeric', minute: '2-digit',
      timeZone: 'America/Los_Angeles', timeZoneName: 'short',
    })
  : null;
---

<div class="mb-6 overflow-hidden rounded-xl border border-slate-800 bg-slate-900">
  {holidays.length > 0 && (
    <div class="border-b border-amber-800/40 bg-amber-950/40 px-6 py-3">
      <span class="text-sm font-semibold text-amber-400">It's {holidays[0]}!</span>
    </div>
  )}

  <div class="p-6">
    <h2 class="mb-3 text-xs font-semibold uppercase tracking-wider text-slate-400">
      Summary
    </h2>

    {condSentences.length > 0 ? (
      <p class="leading-relaxed text-slate-200">{condSentences.join(' ')}</p>
    ) : (
      <p class="text-sm text-slate-500">No current conditions available yet.</p>
    )}
  </div>

  {wordedPeriods.length > 0 && (
    <div class="space-y-4 border-t border-slate-800 px-6 py-5">
      {wordedPeriods.map((p) => {
        const { wiClass, colorClass } = nwsIcon(p.icon_url, p.is_daytime === 1);
        return (
          <div class="flex gap-3">
            <i class={`${wiClass} ${colorClass} mt-0.5 w-6 shrink-0 text-center text-xl leading-none`} aria-hidden="true" />
            <div>
              <span class="font-semibold text-slate-200">{p.name}</span>
              <p class="mt-0.5 text-sm leading-relaxed text-slate-300">{p.detailed_forecast}</p>
            </div>
          </div>
        );
      })}
    </div>
  )}

  <div class="flex flex-wrap items-center gap-x-6 gap-y-2 border-t border-slate-800 px-6 py-4 text-sm">
    <span class="flex items-center gap-2 text-slate-300">
      <i class="wi wi-sunrise text-base text-amber-400" aria-hidden="true"></i>
      <span class="tabular-nums">{formatPacific(sun.sunrise)}</span>
    </span>
    <span class="flex items-center gap-2 text-slate-300">
      <i class="wi wi-sunset text-base text-amber-400" aria-hidden="true"></i>
      <span class="tabular-nums">{formatPacific(sun.sunset)}</span>
    </span>
    <span class="flex items-center gap-2 text-slate-400">
      <i class="wi wi-day-sunny text-base text-amber-400/60" aria-hidden="true"></i>
      <span class="tabular-nums">{formatDayLength(sun.dayLengthMinutes)} of daylight</span>
    </span>
    <span class="flex items-center gap-2 text-slate-300">
      <i class={`wi ${moon.phaseIcon} text-base text-slate-200`} aria-hidden="true"></i>
      <span>{moon.phaseName} · {moon.illumination}% illuminated</span>
    </span>
  </div>

  {synopsis && (
    <details class="group border-t border-slate-800 [&_summary::-webkit-details-marker]:hidden">
      <summary class="cursor-pointer list-none px-6 py-4">
        <div class="flex items-center justify-between gap-3">
          <span class="text-xs font-semibold uppercase tracking-wider text-slate-400">
            Forecast Discussion
          </span>
          <span class="flex items-center gap-2 text-xs text-slate-500">
            {discussion?.office}{afdIssued && ` · ${afdIssued}`}
            <i class="wi wi-direction-down text-sm transition-transform group-open:rotate-180" aria-hidden="true"></i>
          </span>
        </div>
        <p class="mt-2 whitespace-pre-wrap text-sm leading-relaxed text-slate-400 group-open:hidden">{synopsis.body}</p>
      </summary>

      <div class="space-y-4 px-6 pb-6">
        {afdSections.map((s) => (
          <div>
            <h3 class="mb-1 text-xs font-semibold uppercase tracking-wider text-slate-500">{s.name}</h3>
            <p class="whitespace-pre-wrap text-sm leading-relaxed text-slate-400">{s.body}</p>
          </div>
        ))}
      </div>
    </details>
  )}
</div>
