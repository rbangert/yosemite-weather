# Contact email — NWS requires a User-Agent identifying your app + a contact.
CONTACT_EMAIL=you@example.com

# Optional: override the full User-Agent string (defaults to "yosemite-weather (CONTACT_EMAIL)")
# NWS_USER_AGENT=yosemite-weather (you@example.com)

# Path to the SQLite database file (default: data/weather.db)
DB_PATH=data/weather.db

# Port for the REST API (default: 3000)
API_PORT=3000

# How often to poll NWS in milliseconds (default: 900000 = 15 min)
POLL_INTERVAL_MS=900000

# Hours of hourly forecast to retain per point (default: 72)
FORECAST_HOURS=72

# Days of past observations to retain (default: 30)
OBSERVATION_RETENTION_DAYS=30

# Retry transient NWS failures (5xx/429/network) with exponential backoff
NWS_RETRY_MAX_ATTEMPTS=3
NWS_RETRY_BASE_DELAY_MS=500

# ---- Synoptic Mesonet API (optional) ----------------------------------------
# Get a free token at https://developers.synopticdata.com/
# Leave unset to run with NWS-only observations.
SYNOPTIC_API_TOKEN=

# How often to poll Synoptic for observations in milliseconds.
# Free tier: ~500 service units/day (1 SU = 1 station returned).
# Default 3600000 (60 min) keeps ~15 stations x 24 cycles = 360 SU/day.
SYNOPTIC_POLL_INTERVAL_MS=3600000

# Search radius (miles) for finding the nearest Synoptic station per point.
# Larger values find more stations but may match stations far from the point.
SYNOPTIC_RADIUS_MILES=15
